<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720"
			 xmlns:local="using:ReadmeNET"
             x:Class="ReadmeNET.AlertBlockView"
			 x:DataType="local:AlertEditorBlock"
			 >
  
    <Grid Margin="20" RowDefinitions="Auto, Auto" VerticalAlignment="Center">
        <ComboBox FontSize="26" Grid.Row="0" SelectedIndex="{Binding AlertLevel}">
			<ComboBoxItem>NOTE</ComboBoxItem>
			<ComboBoxItem>TIP</ComboBoxItem>
			<ComboBoxItem>IMPORTANT</ComboBoxItem>
			<ComboBoxItem>WARNING</ComboBoxItem>
			<ComboBoxItem>CAUTION</ComboBoxItem>
		</ComboBox>

		<TextBox Grid.Row="1" FontSize="26" Margin="0, 20, 0, 0" Text="{Binding Text}" TextWrapping="Wrap" AcceptsReturn="True" Watermark="Your Text"/>
	</Grid>

</UserControl>
