<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720"
             xmlns:local="using:ReadmeNET"
             x:DataType="local:CodeEditorBlock"
             x:Class="ReadmeNET.CodeBlockView">
  
    <Grid Margin="20" RowDefinitions="Auto, Auto" VerticalAlignment="Center">

		<AutoCompleteBox FontSize="26" Grid.Row="0" Text="{Binding Language}" FilterMode="Contains" ItemsSource="{Binding ProgrammingLanguages}" Watermark="Your language"/>
		<TextBox Margin="0, 20, 0, 0" FontSize="26" Grid.Row="1" Text="{Binding Text}" Watermark="Your code"  AcceptsReturn="True"/>
	</Grid>

</UserControl>
