<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720"
             xmlns:local="using:ReadmeNET"
             x:DataType="local:CollapseEditorBlock"
             x:Class="ReadmeNET.CollapseBlockView">
  
    <Grid Margin="20" RowDefinitions="Auto, Auto" VerticalAlignment="Center">
		<TextBox Grid.Row="0" FontSize="26"  Text="{Binding Title}" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="150" Watermark="Your Title"/>
		<TextBox Grid.Row="1" FontSize="26" Margin="0, 20, 0, 0" Text="{Binding Text}" TextWrapping="Wrap" AcceptsReturn="True" Watermark="Your Description"/>
	</Grid>

</UserControl>
