<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="720"
			 xmlns:local="using:ReadmeNET"
			 x:DataType="local:QuoteEditorBlock"
             x:Class="ReadmeNET.QuoteBlockView">
  
    <Grid Margin="20" VerticalAlignment="Center">
		<TextBox FontSize="26"  Text="{Binding Text}" TextWrapping="Wrap" AcceptsReturn="True" MaxHeight="150" Watermark="Your Quote"/>
	</Grid>

</UserControl>
